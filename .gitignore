# Dependencies
node_modules/

# Build output
dist/
build/
web-build/

# Env / secrets — never commit these (keep .env.example)
.env
.env.*
!.env.example

# Firebase service-account key (FCM V1) — SECRET, never commit.
# google-services.json is a client config and IS committed (build needs it).
private-key.json
*-firebase-adminsdk-*.json
google-service-account*.json

# Logs
*.log
npm-debug.log*
yarn-error.log*

# Expo / React Native
.expo/
*.tsbuildinfo
expo-env.d.ts
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Native build artifacts
android/
ios/

# OS / editor
.DS_Store
Thumbs.db
.idea/
