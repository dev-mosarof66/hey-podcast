# Server
PORT=4000
NODE_ENV=development

# NeonDB connection string (get it from your Neon dashboard)
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Set to "true" to auto-sync schema in dev (do NOT use in production; use migrations instead)
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Auth
# Long random string used to sign JWTs (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
# Google OAuth Web client id — used to verify ID tokens from the app
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Admin panel — comma-separated emails allowed into /api/admin/*
ADMIN_EMAILS=you@example.com

# ── Generation engine (optional) ────────────────────────────────────────────
# Without both keys the server uses placeholder audio. With them, /episodes/
# generate runs the real pipeline: Gemini (brief + script) → Deepgram (voices).
# Gemini key — free at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Deepgram key — free $200 credit at https://console.deepgram.com
DEEPGRAM_API_KEY=
# Base URL the phone uses to reach this server, for absolute audio links.
# MUST be your LAN IP in dev (not localhost) so the device can load the audio.
# Only used for the local-disk fallback when Cloudinary isn't configured.
PUBLIC_URL=http://192.168.0.104:4000

# Cloudinary — audio hosting (CDN). Free, no card. From your Cloudinary
# dashboard "Product Environment Credentials". Absent → audio served locally.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Per-user digest cron: pre-generate each user's personalized episode.
# Default 4:30 AM. Set DIGEST_CRON=off to disable.
DIGEST_CRON=30 4 * * *
# Global digest cron: pre-generate one shared episode per topic (seen by all).
# Default 2 AM. Set GLOBAL_DIGEST_CRON=off to disable.
GLOBAL_DIGEST_CRON=0 2 * * *
DIGEST_TZ=Asia/Dhaka
