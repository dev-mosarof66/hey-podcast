{
  "expo": {
    "name": "Daily Download",
    "slug": "hey-podcast",
    "version": "2.0.0",
    "scheme": "heypodcast",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/splash-icon.png"
    },
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "expo-audio",
      [
        "expo-notifications",
        {
          "color": "#721378"
        }
      ],
      "expo-font"
    ],
    "orientation": "portrait",
    "icon": "./assets/playstore-icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3e8ff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.heypodcast.app",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon.png",
        "backgroundColor": "#4c1d95"
      },
      "package": "com.heypodcast.app",
      "googleServicesFile": "./google-services.json"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df400f67-8164-4366-b069-dd7a51fe31db"
      }
    }
  }
}
